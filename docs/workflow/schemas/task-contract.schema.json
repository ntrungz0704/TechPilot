{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/workflow/schemas/task-contract.schema.json",
  "title": "Checkpoint Task Contract",
  "description": "Machine-readable task contract for a checkpoint. Mirrors and extends the YAML front-matter convention in docs/checkpoints/.",
  "type": "object",
  "required": [
    "schema_version",
    "checkpoint_id",
    "phase_id",
    "title",
    "lifecycle_status",
    "base_sha",
    "scope"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+$" },
    "checkpoint_id": { "type": "string", "pattern": "^CHECKPOINT_[0-9]+$" },
    "phase_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "ROADMAP_DEFINED", "CONTRACT_DRAFTED", "CONTRACT_APPROVED",
        "IMPLEMENTING", "CI_PENDING", "CI_FAILED", "CI_GREEN",
        "WAITING_FOR_HERMES", "REWORK_REQUIRED", "HERMES_VERIFIED",
        "WAITING_FOR_SEMANTIC_REVIEW", "SEMANTIC_CHANGES_REQUIRED",
        "SEMANTIC_APPROVED", "MERGE_READY", "MERGED", "CLOSED"
      ]
    },
    "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "candidate_sha": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        { "type": "null" }
      ]
    },
    "reviewed_sha": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        { "type": "null" }
      ]
    },
    "scope": {
      "type": "object",
      "required": ["in_scope", "out_of_scope", "allowed_paths", "forbidden_paths"],
      "properties": {
        "in_scope": { "type": "array", "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } },
        "allowed_paths": { "type": "array", "items": { "type": "string" } },
        "forbidden_paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "expected_exit_code"],
        "properties": {
          "command": { "type": "string" },
          "expected_exit_code": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "required_evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "severity", "mitigation"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "contract_path": { "type": "string" },
    "handoff_path": { "type": "string" },
    "last_updated": { "type": "string", "format": "date-time" }
  }
}

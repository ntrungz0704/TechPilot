#!/usr/bin/env bash
set -euo pipefail

CONTRACT="${1:-checkpoints/CP03/TASK_CONTRACT.yaml}"
BASE_SHA="${2:-}"
STATE_FILE="checkpoints/STATE.json"

# Determine lifecycle for enforcement mode
LIFECYCLE=""
if [ -f "$STATE_FILE" ]; then
  LIFECYCLE=$(grep '"lifecycle_status"' "$STATE_FILE" | awk -F'"' '{print $4}' 2>/dev/null || echo "")
fi
: "${LIFECYCLE:=unknown}"

echo "Lifecycle: $LIFECYCLE"

# Pre-approval lifecycle: only check workflow files, not full feature branch diff
PRE_APPROVAL=false
case "$LIFECYCLE" in
  ROADMAP_DEFINED|CONTRACT_DRAFTED|CONTRACT_APPROVED|"") PRE_APPROVAL=true;;
esac

if [ "$PRE_APPROVAL" = true ]; then
  echo "Mode: pre-approval (scanning only workflow infrastructure files)"
  HEAD_SHA=$(git rev-parse HEAD)
  WORKFLOW_FILES=$(git diff --name-only "$BASE_SHA..$HEAD_SHA" 2>/dev/null | grep -E '^(scripts/workflow/|\.opencode/|AGENTS\.md|checkpoints/|docs/workflow/)' || true)
  
  if [ -z "$WORKFLOW_FILES" ]; then
    echo "OK: No workflow infrastructure files to scan"
    echo "PASS: scan-forbidden-patterns"
    exit 0
  fi
  
  VIOLATIONS=0
  # Simple check: ensure no absolute paths in workflow scripts
  for f in $WORKFLOW_FILES; do
    if [ -f "$f" ]; then
      # Check for Windows absolute paths
      if grep -qE '"[A-Za-z]:\\' "$f" 2>/dev/null; then
        echo "VIOLATION: Absolute Windows path in $f"
        VIOLATIONS=$((VIOLATIONS + 1))
      fi
    fi
  done
  
  if [ "$VIOLATIONS" -gt 0 ]; then
    echo "FAIL: $VIOLATIONS violation(s) in workflow files"
    exit 1
  fi
  echo "OK: No forbidden patterns in workflow infrastructure files"
  echo "PASS: scan-forbidden-patterns"
  exit 0
fi

# Post-approval: full diff scan (CP03 implementation mode)
if [ -z "$BASE_SHA" ]; then
  if [ -f "$CONTRACT" ]; then
    BASE_SHA=$(grep '^BASE_SHA:' "$CONTRACT" | awk '{print $2}' | tr -d ' "')
  fi
fi

if [ -z "$BASE_SHA" ]; then
  echo "FAIL: Could not determine base SHA"
  exit 1
fi

if ! git rev-parse --verify "$BASE_SHA" &>/dev/null; then
  echo "FAIL: Base SHA '$BASE_SHA' is not a valid git reference"
  exit 1
fi

HEAD_SHA=$(git rev-parse HEAD)
echo "Scanning diff range: $BASE_SHA...$HEAD_SHA"

DIFF_CONTENT=$(git diff "$BASE_SHA...$HEAD_SHA" 2>/dev/null || git diff "$BASE_SHA..$HEAD_SHA" 2>/dev/null || true)

if [ -z "$DIFF_CONTENT" ]; then
  echo "OK: No diff content to scan"
  echo "PASS: scan-forbidden-patterns"
  exit 0
fi

VIOLATIONS=0
ADDED_LINES=$(echo "$DIFF_CONTENT" | grep "^\+" | grep -v "^+++" || true)

# Pattern 1: debugger statements (excluding the scan script itself)
if echo "$DIFF_CONTENT" | grep -n "^\+.*debugger;" | grep -v "scan-forbidden-patterns" | grep -v 'grep.*debugger' &>/dev/null; then
  echo "VIOLATION: debugger; statement found in diff"
  echo "$DIFF_CONTENT" | grep -n "^\+.*debugger;" | grep -v "scan-forbidden-patterns" | grep -v 'grep.*debugger' | head -5
  VIOLATIONS=$((VIOLATIONS + 1))
fi

# Pattern 2: Hardcoded secrets (exclude test files and schema files)
while IFS= read -r line; do
  line_content=$(echo "$line" | sed 's/^+//')
  file_path=$(echo "$line_content" | grep -oP '^[^:]+' || true)
  [ -z "$line_content" ] && continue
  if echo "$line" | grep -qE 'tests/|\.schema\.json|schema\.json'; then continue; fi
  if echo "$line_content" | grep -qE '(api_key|apikey|api\.key)\s*[=:]\s*["'"'"']{1}[a-zA-Z0-9]{16,}["'"'"']{1}'; then
    echo "VIOLATION: Possible hardcoded API key"
    echo "  $(echo "$line_content" | head -1)"
    VIOLATIONS=$((VIOLATIONS + 1))
  fi
  if echo "$line_content" | grep -qE '(password|secret|token)\s*[=:]\s*["'"'"']{1}[a-zA-Z0-9!@#$%^&*()_+=-]{8,}["'"'"']{1}'; then
    echo "VIOLATION: Possible hardcoded password/secret/token"
    echo "  $(echo "$line_content" | head -1)"
    VIOLATIONS=$((VIOLATIONS + 1))
  fi
done <<< "$ADDED_LINES"

# Pattern 3: Governance file modifications
if echo "$DIFF_CONTENT" | grep "^diff --git a/docs/governance/" &>/dev/null; then
  echo "VIOLATION: Governance file modification detected"
  echo "$DIFF_CONTENT" | grep "^diff --git a/docs/governance/" | head -5
  VIOLATIONS=$((VIOLATIONS + 1))
fi

if [ "$VIOLATIONS" -gt 0 ]; then
  echo "FAIL: $VIOLATIONS forbidden pattern violation(s) found"
  exit 1
fi

echo "OK: No forbidden patterns found in diff"
echo "PASS: scan-forbidden-patterns"
exit 0

#!/usr/bin/env bash
set -euo pipefail

CONTRACT="${1:-checkpoints/CP03/TASK_CONTRACT.yaml}"
BASE_SHA="${2:-}"
STATE_FILE="checkpoints/STATE.json"

# Determine lifecycle for enforcement mode
LIFECYCLE=""
if [ -f "$STATE_FILE" ]; then
  LIFECYCLE=$(grep '"lifecycle_status"' "$STATE_FILE" | awk -F'"' '{print $4}' 2>/dev/null || echo "")
fi
: "${LIFECYCLE:=unknown}"

echo "Lifecycle: $LIFECYCLE"

# Pre-approval lifecycle: only check workflow vs production mixing
PRE_APPROVAL=false
case "$LIFECYCLE" in
  ROADMAP_DEFINED|CONTRACT_DRAFTED|CONTRACT_APPROVED|"") PRE_APPROVAL=true;;
esac

if [ "$PRE_APPROVAL" = true ]; then
  echo "Mode: pre-approval (checking workflow vs production mixing only)"
  HEAD_SHA=$(git rev-parse HEAD)
  
  # For pre-approval, use parent commits as base if not specified
  if [ -z "$BASE_SHA" ]; then
    BASE_SHA="${2:-$(git rev-parse HEAD~1 2>/dev/null || echo "")}"
    if [ -z "$BASE_SHA" ]; then
      echo "OK: No base SHA specified and no parent commit — single commit repo"
      echo "PASS: check-changed-files"
      exit 0
    fi
  fi
  
  CHANGED_FILES=$(git diff --name-only "$BASE_SHA..$HEAD_SHA" 2>/dev/null || true)
  
  if [ -z "$CHANGED_FILES" ]; then
    echo "OK: No changed files detected in diff range $BASE_SHA..$HEAD_SHA"
    echo "PASS: check-changed-files"
    exit 0
  fi
  
  echo "Changed files (pre-approval mode):"
  echo "$CHANGED_FILES"
  
  # Check for workflow/production mixing
  WORKFLOW_PATTERNS="^(checkpoints/|docs/workflow/|scripts/workflow/|\.opencode/|AGENTS\.md|\.github/workflows/|tests/workflow/)"
  PRODUCTION_PATTERNS="^(app/|config/|database/|public/|techpilot/|tests/(?!workflow/))"
  
  HAS_WORKFLOW=false
  HAS_PRODUCTION=false
  
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    if [[ "$file" =~ $WORKFLOW_PATTERNS ]]; then HAS_WORKFLOW=true; fi
    if [[ "$file" =~ $PRODUCTION_PATTERNS ]]; then HAS_PRODUCTION=true; fi
  done <<< "$CHANGED_FILES"
  
  if [ "$HAS_WORKFLOW" = true ] && [ "$HAS_PRODUCTION" = true ]; then
    echo "FAIL: Mixed changes — workflow and production files in same diff"
    echo "Separate workflow infrastructure changes from production code changes."
    exit 1
  fi
  
  echo "OK: No forbidden mixing detected"
  echo "PASS: check-changed-files"
  exit 0
fi

# Post-approval lifecycle: enforce contract allowed/forbidden paths
if [ -z "$BASE_SHA" ]; then
  if [ -f "$CONTRACT" ]; then
    BASE_SHA=$(grep '^BASE_SHA:' "$CONTRACT" | awk '{print $2}' | tr -d ' "')
  fi
fi

if [ -z "$BASE_SHA" ]; then
  echo "FAIL: Could not determine base SHA. Provide as argument or in TASK_CONTRACT.yaml"
  exit 1
fi

if ! git rev-parse --verify "$BASE_SHA" &>/dev/null; then
  echo "FAIL: Base SHA '$BASE_SHA' is not a valid git reference"
  exit 1
fi

HEAD_SHA=$(git rev-parse HEAD)
echo "Diff range: $BASE_SHA...$HEAD_SHA"

CHANGED_FILES=$(git diff --name-only "$BASE_SHA...$HEAD_SHA" 2>/dev/null || git diff --name-only "$BASE_SHA..$HEAD_SHA" 2>/dev/null || true)

if [ -z "$CHANGED_FILES" ]; then
  echo "OK: No changed files detected"
  echo "PASS: check-changed-files"
  exit 0
fi

echo "Changed files:"
echo "$CHANGED_FILES"

# Parse allowed and forbidden paths from contract
ALLOWED_PATHS=""
FORBIDDEN_PATHS=""

if [ -f "$CONTRACT" ]; then
  ALLOWED_PATHS=$(grep -A100 '^ALLOWED_PATHS:' "$CONTRACT" | grep '^  - ' | sed 's/^  - //' | sed 's/^"//;s/"$//' 2>/dev/null || true)
  FORBIDDEN_PATHS=$(grep -A100 '^FORBIDDEN_PATHS:' "$CONTRACT" | grep '^  - ' | sed 's/^  - //' | sed 's/^"//;s/"$//' 2>/dev/null || true)
fi

# Check each changed file against allowed/forbidden paths
VIOLATIONS=0
while IFS= read -r file; do
  [ -z "$file" ] && continue
  
  # Remove leading/trailing quotes if any
  file="${file#\"}"; file="${file%\"}"
  file="${file#\'}"; file="${file%\'}"

  in_allowed_paths=false
  in_forbidden_paths=false

  if [ -n "$ALLOWED_PATHS" ]; then
    while IFS= read -r pattern; do
      [ -z "$pattern" ] && continue
      # Convert glob pattern to regex
      regex=$(echo "$pattern" | sed 's/\./\\./g; s/\*\*/[^\/]*/g; s/\*/[^\/]*/g; s/\?/./g')
      # Handle trailing /** patterns
      if [[ "$pattern" == *"/**" ]]; then
        base="${pattern%/**}"
        base_regex=$(echo "$base" | sed 's/\./\\./g; s/\*\*/[^\/]*/g; s/\*/[^\/]*/g; s/\?/./g')
        if [[ "$file" == "$base"* ]]; then
          in_allowed_paths=true
        fi
      elif [[ "$file" == $pattern ]] || [[ "$file" == $pattern* ]]; then
        in_allowed_paths=true
      fi
    done <<< "$ALLOWED_PATHS"
  else
    # No allowed_paths in contract means everything is allowed
    in_allowed_paths=true
  fi

  if [ -n "$FORBIDDEN_PATHS" ]; then
    while IFS= read -r pattern; do
      [ -z "$pattern" ] && continue
      if [[ "$pattern" == *"/**" ]]; then
        base="${pattern%/**}"
        if [[ "$file" == "$base"* ]]; then
          in_forbidden_paths=true
        fi
      elif [[ "$file" == $pattern ]] || [[ "$file" == $pattern* ]]; then
        in_forbidden_paths=true
      fi
    done <<< "$FORBIDDEN_PATHS"
  fi

  if [ "$in_forbidden_paths" = true ]; then
    echo "VIOLATION: '$file' is in forbidden_paths"
    VIOLATIONS=$((VIOLATIONS + 1))
  elif [ "$in_allowed_paths" = false ]; then
    echo "VIOLATION: '$file' is not in allowed_paths"
    VIOLATIONS=$((VIOLATIONS + 1))
  fi
done <<< "$CHANGED_FILES"

if [ "$VIOLATIONS" -gt 0 ]; then
  echo "FAIL: $VIOLATIONS path violation(s) found"
  exit 1
fi

echo "OK: All changed files are within allowed_paths and not in forbidden_paths"
echo "PASS: check-changed-files"
exit 0

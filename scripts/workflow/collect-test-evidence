#!/usr/bin/env bash
set -euo pipefail

CONTRACT="${1:-checkpoints/CP03/TASK_CONTRACT.yaml}"
EVIDENCE_DIR="${2:-checkpoints/CP03/evidence}"
STATE_FILE="checkpoints/STATE.json"

# Determine lifecycle
LIFECYCLE=""
if [ -f "$STATE_FILE" ]; then
  LIFECYCLE=$(grep '"lifecycle_status"' "$STATE_FILE" | awk -F'"' '{print $4}' 2>/dev/null || echo "")
fi
: "${LIFECYCLE:=unknown}"

# Pre-approval: skip required_tests execution (no CP03 implementation yet)
PRE_APPROVAL=false
case "$LIFECYCLE" in
  ROADMAP_DEFINED|CONTRACT_DRAFTED|CONTRACT_APPROVED|"") PRE_APPROVAL=true;;
esac

if [ "$PRE_APPROVAL" = true ]; then
  echo "Mode: pre-approval — collecting infrastructure evidence only"
  HEAD_SHA=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
  BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
  TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  mkdir -p "$EVIDENCE_DIR"
  {
    echo "# Pre-approval Infrastructure Evidence"
    echo "Timestamp: $TIMESTAMP"
    echo "HEAD SHA: $HEAD_SHA"
    echo "Branch: $BRANCH"
    echo "Lifecycle: $LIFECYCLE"
    echo ""
    echo "=== Git Status ==="
    git status --short 2>&1 || true
    echo ""
    echo "=== Workflow Files ==="
    git ls-files scripts/workflow/ .opencode/ AGENTS.md checkpoints/ docs/workflow/ 2>/dev/null || true
    echo ""
    echo "=== Validation ==="
    echo "validate-contract: skipped (pre-approval)"
    echo "required_tests: skipped (pre-approval, no CP03 implementation)"
  } > "$EVIDENCE_DIR/test-summary.txt"
  echo "Infrastructure evidence collected at $EVIDENCE_DIR/test-summary.txt"
  echo "PASS: collect-test-evidence (pre-approval mode)"
  exit 0
fi

if [ ! -f "$CONTRACT" ]; then
  echo "FAIL: Contract file not found: $CONTRACT"
  exit 1
fi

HEAD_SHA=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

mkdir -p "$EVIDENCE_DIR"
SUMMARY_FILE="$EVIDENCE_DIR/test-summary.txt"

{
  echo "# Test Evidence Collection"
  echo "Timestamp: $TIMESTAMP"
  echo "HEAD SHA: $HEAD_SHA"
  echo "Branch: $BRANCH"
  echo ""
} > "$SUMMARY_FILE"

# Parse REQUIRED_TESTS from contract
if command -v php &> /dev/null; then
  TESTS=$(php -r '
$yaml = file_get_contents("'"$CONTRACT"'");
$lines = explode("\n", $yaml);
$in_tests = false;
$in_command = false;
$in_exit_code = false;
$current_cmd = "";
$current_exit = "";
foreach ($lines as $line) {
  $trimmed = trim($line);
  if ($trimmed === "REQUIRED_TESTS:" || $trimmed === "REQUIRED_TESTS") { $in_tests = true; continue; }
  if ($in_tests && preg_match("/^[A-Z_]+:/", $trimmed)) { $in_tests = false; continue; }
  if ($in_tests && preg_match("/^\s*-?\s*command:\s*(.+)$/", $trimmed, $m)) { $current_cmd = trim($m[1]); }
  if ($in_tests && preg_match("/^\s*-?\s*expected_exit_code:\s*(\d+)$/", $trimmed, $m)) { $current_exit = $m[1]; }
  if ($in_tests && $current_cmd !== "" && $current_exit !== "") {
    echo $current_cmd . "|" . $current_exit . "\n";
    $current_cmd = ""; $current_exit = "";
  }
}
' 2>/dev/null || true)
else
  echo "FAIL: php is required to parse contract tests"
  exit 1
fi

if [ -z "$TESTS" ]; then
  echo "FAIL: No REQUIRED_TESTS found in contract"
  {
    echo "FAIL: No REQUIRED_TESTS found in contract"
    echo "Please add REQUIRED_TESTS to $CONTRACT"
  } >> "$SUMMARY_FILE"
  exit 1
fi

ANY_FAILED=0

while IFS='|' read -r cmd expected_exit; do
  [ -z "$cmd" ] && continue
  echo "Running: $cmd"
  
  # Capture output and exit code
  set +e
  output=$(eval "$cmd" 2>&1)
  actual_exit=$?
  set -e
  
  {
    echo "=== Test: $cmd ==="
    echo "Command: $cmd"
    echo "Expected exit code: $expected_exit"
    echo "Actual exit code: $actual_exit"
    echo "Output:"
    echo "$output"
    echo ""
  } >> "$SUMMARY_FILE"
  
  if [ "$actual_exit" != "$expected_exit" ]; then
    echo "FAIL: '$cmd' exited $actual_exit, expected $expected_exit"
    ANY_FAILED=1
  else
    echo "OK: '$cmd' exited $actual_exit (expected $expected_exit)"
  fi
done <<< "$TESTS"

# Also capture git status and changed files
{
  echo "=== Git Status ==="
  git status --short 2>&1 || true
  echo ""
  echo "=== Changed Files (from base) ==="
  BASE_SHA=$(grep '^BASE_SHA:' "$CONTRACT" | awk '{print $2}' | tr -d ' "' 2>/dev/null || echo "")
  if [ -n "$BASE_SHA" ] && git rev-parse --verify "$BASE_SHA" &>/dev/null; then
    git diff --name-only "$BASE_SHA...$HEAD_SHA" 2>/dev/null || git diff --name-only "$BASE_SHA..$HEAD_SHA" 2>/dev/null || true
  else
    git diff --name-only HEAD 2>/dev/null || true
  fi
  echo ""
  echo "=== Git Diff Stat ==="
  if [ -n "$BASE_SHA" ] && git rev-parse --verify "$BASE_SHA" &>/dev/null; then
    git diff --stat "$BASE_SHA...$HEAD_SHA" 2>/dev/null || git diff --stat "$BASE_SHA..$HEAD_SHA" 2>/dev/null || true
  fi
} >> "$SUMMARY_FILE"

echo "Evidence collected at $SUMMARY_FILE"

if [ "$ANY_FAILED" -eq 1 ]; then
  echo "FAIL: One or more required tests failed"
  exit 1
fi

echo "PASS: collect-test-evidence"
exit 0

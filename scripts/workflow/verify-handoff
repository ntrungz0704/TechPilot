#!/usr/bin/env bash
set -euo pipefail

HANDOFF="${1:-checkpoints/CP03/IMPLEMENTATION_HANDOFF.json}"
CONTRACT="${2:-checkpoints/CP03/TASK_CONTRACT.yaml}"

if [ ! -f "$HANDOFF" ]; then
  echo "FAIL: Handoff file not found: $HANDOFF"
  exit 1
fi

if ! command -v jq &> /dev/null; then
  echo "FAIL: jq is required for handoff verification"
  exit 1
fi

# Validate JSON
if ! jq '.' "$HANDOFF" &>/dev/null; then
  echo "FAIL: Handoff is not valid JSON"
  exit 1
fi

# Required fields
REQUIRED_FIELDS=("checkpoint_id" "candidate_sha" "changed_files" "test_results" "writer_declaration")
for field in "${REQUIRED_FIELDS[@]}"; do
  if ! jq -e ".$field" "$HANDOFF" &>/dev/null; then
    echo "FAIL: Required field '$field' is missing from handoff"
    exit 1
  fi
done

# Checkpoint ID must match
HANDOFF_CID=$(jq -r '.checkpoint_id' "$HANDOFF")
EXPECTED_CID="CHECKPOINT_3"
if [ "$HANDOFF_CID" != "$EXPECTED_CID" ]; then
  echo "FAIL: Handoff checkpoint_id '$HANDOFF_CID' does not match expected '$EXPECTED_CID'"
  exit 1
fi

# Check writer_declaration
DECL=$(jq -r '.writer_declaration' "$HANDOFF")
if [ "$DECL" = "GATE_PASS" ]; then
  echo "FAIL: Writer declared GATE_PASS. Writer may only declare READY_FOR_REVIEW"
  exit 1
fi
if [ "$DECL" = "PENDING_IMPLEMENTATION" ]; then
  echo "FAIL: Handoff is in PENDING_IMPLEMENTATION state. Implementation must be complete before handoff"
  exit 1
fi
if [ "$DECL" != "READY_FOR_REVIEW" ]; then
  echo "FAIL: Invalid writer_declaration '$DECL'. Must be READY_FOR_REVIEW"
  exit 1
fi

# candidate_sha must be a full 40-char SHA or valid ref
CANDIDATE_SHA=$(jq -r '.candidate_sha' "$HANDOFF")
if [ "$CANDIDATE_SHA" = "CANDIDATE_COMMIT_PENDING_HUMAN_COMMIT" ]; then
  echo "FAIL: candidate_sha is placeholder 'CANDIDATE_COMMIT_PENDING_HUMAN_COMMIT'. Must be actual SHA"
  exit 1
fi
if ! echo "$CANDIDATE_SHA" | grep -qE '^[0-9a-f]{40}$'; then
  echo "FAIL: candidate_sha '$CANDIDATE_SHA' is not a valid 40-char SHA"
  exit 1
fi

# candidate_sha must equal HEAD
HEAD_SHA=$(git rev-parse HEAD)
if [ "$CANDIDATE_SHA" != "$HEAD_SHA" ]; then
  echo "FAIL: Handoff candidate_sha ($CANDIDATE_SHA) does not match HEAD ($HEAD_SHA)"
  exit 1
fi

# Verify changed_files matches git diff
BASE_SHA=""
if [ -f "$CONTRACT" ]; then
  BASE_SHA=$(grep '^BASE_SHA:' "$CONTRACT" | awk '{print $2}' | tr -d ' "')
fi

if [ -n "$BASE_SHA" ] && git rev-parse --verify "$BASE_SHA" &>/dev/null; then
  HANDOFF_FILES=$(jq -r '.changed_files[]' "$HANDOFF" 2>/dev/null | sort)
  GIT_FILES=$(git diff --name-only "$BASE_SHA...$HEAD_SHA" 2>/dev/null | sort || git diff --name-only "$BASE_SHA..$HEAD_SHA" 2>/dev/null | sort || true)
  
  if [ "$HANDOFF_FILES" != "$GIT_FILES" ]; then
    echo "FAIL: Handoff changed_files does not match git diff"
    echo "--- Handoff claims ---"
    echo "$HANDOFF_FILES"
    echo "--- Git diff shows ---"
    echo "$GIT_FILES"
    exit 1
  fi
  echo "OK: Handoff changed_files matches git diff"
fi

# Verify test_results are present
TEST_COUNT=$(jq '.test_results | length' "$HANDOFF")
if [ "$TEST_COUNT" -eq 0 ]; then
  echo "FAIL: Handoff has no test_results"
  exit 1
fi

# Verify all tests passed (exit_code = 0)
FAILED_TESTS=$(jq '[.test_results[] | select(.exit_code != 0)] | length' "$HANDOFF")
if [ "$FAILED_TESTS" -gt 0 ]; then
  echo "FAIL: $FAILED_TESTS test(s) in handoff have non-zero exit code"
  jq '.test_results[] | select(.exit_code != 0) | "\(.command): exit \(.exit_code)"' "$HANDOFF"
  exit 1
fi

echo "OK: Handoff checkpoint_id=$HANDOFF_CID, candidate=$CANDIDATE_SHA, declaration=$DECL"
echo "PASS: verify-handoff"
exit 0

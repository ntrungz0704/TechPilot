#!/usr/bin/env bash
set -euo pipefail

CONTRACT="${1:-checkpoints/CP03/TASK_CONTRACT.yaml}"
SCHEMA="${2:-docs/workflow/schemas/task-contract.schema.json}"

if [ ! -f "$CONTRACT" ]; then
  ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
  if [ -n "$ROOT" ] && [ -f "$ROOT/$CONTRACT" ]; then
    CONTRACT="$ROOT/$CONTRACT"
  else
    echo "FAIL: Contract file not found: $CONTRACT"
    exit 1
  fi
fi

if [ ! -f "$SCHEMA" ]; then
  ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
  if [ -n "$ROOT" ] && [ -f "$ROOT/$SCHEMA" ]; then
    SCHEMA="$ROOT/$SCHEMA"
  else
    echo "FAIL: Schema file not found: $SCHEMA"
    exit 1
  fi
fi

if ! command -v php &> /dev/null; then
  echo "FAIL: php is required for contract validation"
  exit 1
fi

if ! command -v node &> /dev/null; then
  echo "FAIL: node is required for schema validation"
  exit 1
fi

# 1. Extract and validate scalar fields using grep (always works)
CHECKPOINT_ID=$(grep '^CHECKPOINT_ID:' "$CONTRACT" | awk -F': ' '{print $2}' | tr -d '["'"'"' ]' || true)
if [ "$CHECKPOINT_ID" != "CHECKPOINT_3" ]; then
  echo "FAIL: CHECKPOINT_ID is '${CHECKPOINT_ID:-empty}', expected CHECKPOINT_3"
  exit 1
fi
echo "OK: CHECKPOINT_ID=$CHECKPOINT_ID"

LIFECYCLE=$(grep '^LIFECYCLE_STATUS:' "$CONTRACT" | awk -F': ' '{print $2}' | tr -d '["'"'"' ]' || true)
VALID=false
for state in ROADMAP_DEFINED CONTRACT_DRAFTED CONTRACT_APPROVED IMPLEMENTING CI_PENDING CI_FAILED CI_GREEN WAITING_FOR_HERMES REWORK_REQUIRED HERMES_VERIFIED WAITING_FOR_SEMANTIC_REVIEW SEMANTIC_CHANGES_REQUIRED SEMANTIC_APPROVED MERGE_READY MERGED CLOSED; do
  [ "$LIFECYCLE" = "$state" ] && VALID=true && break
done
if [ "$VALID" = false ]; then
  echo "FAIL: Invalid LIFECYCLE_STATUS '${LIFECYCLE:-empty}'"
  exit 1
fi
echo "OK: LIFECYCLE_STATUS=$LIFECYCLE"

BASE_SHA=$(grep '^BASE_SHA:' "$CONTRACT" | awk -F': ' '{print $2}' | tr -d '["'"'"' ]' || true)
if ! echo "$BASE_SHA" | grep -qE '^[0-9a-f]{40}$'; then
  echo "FAIL: BASE_SHA '${BASE_SHA:-empty}' is not a valid 40-char SHA"
  exit 1
fi
echo "OK: BASE_SHA=$BASE_SHA"

# 2. Validate scope sections exist
if ! grep -q '^SCOPE:' "$CONTRACT"; then echo "FAIL: Missing SCOPE section"; exit 1; fi
if ! grep -q '^ALLOWED_PATHS:' "$CONTRACT"; then echo "FAIL: Missing ALLOWED_PATHS"; exit 1; fi
if ! grep -q '^FORBIDDEN_PATHS:' "$CONTRACT"; then echo "FAIL: Missing FORBIDDEN_PATHS"; exit 1; fi
if ! grep -q '^ACCEPTANCE_CRITERIA:' "$CONTRACT"; then echo "FAIL: Missing ACCEPTANCE_CRITERIA"; exit 1; fi
if ! grep -q '^REQUIRED_TESTS:' "$CONTRACT"; then echo "FAIL: Missing REQUIRED_TESTS"; exit 1; fi
echo "OK: All required sections present"

# 3. PHP inline structure validation (read via stdin to avoid path issues)
echo "OK: All sections verified via grep"

# 4. Schema validation via Node
# Convert backslashes to forward slashes for Node.js path compatibility
NODE_SCHEMA=$(echo "$SCHEMA" | sed 's|\\|/|g')
NODE_CONTRACT=$(echo "$CONTRACT" | sed 's|\\|/|g')
node -e "
const fs = require('fs');
const schema = JSON.parse(fs.readFileSync('$NODE_SCHEMA', 'utf8'));
const yaml = fs.readFileSync('$NODE_CONTRACT', 'utf8');
const contract = {};
const lines = yaml.split('\n');
for (const line of lines) {
  const m = line.match(/^([A-Z_]+):\s*(.+)$/);
  if (m) {
    let val = m[2].trim();
    if (val === 'null') contract[m[1]] = null;
    else if (val === 'true') contract[m[1]] = true;
    else if (val === 'false') contract[m[1]] = false;
    else if (/^\d+$/.test(val)) contract[m[1]] = parseInt(val, 10);
    else contract[m[1]] = val.replace(/^\"|\"$/g, '');
  }
}
const sections = ['SCOPE','ACCEPTANCE_CRITERIA','REQUIRED_TESTS','REQUIRED_EVIDENCE','OUT_OF_SCOPE'];
for (const s of sections) {
  if (yaml.includes(s + ':')) contract[s] = s === 'SCOPE' ? {ALLOWED_PATHS:[],FORBIDDEN_PATHS:[]} : [];
}

const errors = [];
const required = schema.required || [];
for (const r of required) {
  if (!(r in contract)) errors.push('Missing required: ' + r);
}
for (const [key, def] of Object.entries(schema.properties || {})) {
  if (key in contract && contract[key] !== null) {
    if (def.type === 'string' && typeof contract[key] !== 'string') errors.push(key + ': expected string');
    if (def.enum && !def.enum.includes(contract[key])) errors.push(key + ': invalid enum: ' + contract[key]);
    if (def.pattern && typeof contract[key] === 'string' && !new RegExp('^'+def.pattern+'$').test(contract[key]))
      errors.push(key + ': pattern mismatch');
  }
}
if (errors.length > 0) { errors.forEach(e => console.log('SCHEMA ERROR: '+e)); process.exit(1); }
console.log('OK: Schema validation passed');
" 2>&1 || { echo "FAIL: Schema validation failed"; exit 1; }

echo "PASS: validate-contract"
exit 0

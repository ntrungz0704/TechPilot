#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="checkpoints/STATE.json"
EXPECTED_SHA="${1:-}"

CURRENT_HEAD=$(git rev-parse HEAD 2>/dev/null || echo "unknown")

if [ -n "$EXPECTED_SHA" ]; then
  if [ "$CURRENT_HEAD" != "$EXPECTED_SHA" ]; then
    echo "FAIL: HEAD ($CURRENT_HEAD) does not match expected SHA ($EXPECTED_SHA)"
    exit 1
  fi
  echo "OK: HEAD matches expected SHA"
fi

# Verify against state file if it exists
if [ -f "$STATE_FILE" ]; then
  if ! command -v jq &> /dev/null; then
    echo "SKIPPED_PRECONDITION: jq not available — cannot parse STATE.json"
    echo "CURRENT_HEAD=$CURRENT_HEAD"
    echo "PASS: verify-review-sha (limited)"
    exit 0
  fi
  REVIEWED_SHA=$(jq -r '.reviewed_sha // "null"' "$STATE_FILE")
  if [ "$REVIEWED_SHA" != "null" ] && [ "$REVIEWED_SHA" != "$CURRENT_HEAD" ]; then
    echo "FAIL: HEAD ($CURRENT_HEAD) does not match reviewed SHA ($REVIEWED_SHA) in state file"
    echo "New commit detected after review. Review is invalidated."
    exit 1
  fi

  if [ "$REVIEWED_SHA" != "null" ]; then
    echo "OK: HEAD matches reviewed SHA in state file"
  fi
fi

echo "CURRENT_HEAD=$CURRENT_HEAD"
echo "PASS: verify-review-sha"
exit 0
